# Backend
NODE_ENV=development
PORT=5000

# Frontend URL for CORS (Vercel URL in production)
CLIENT_URL=http://localhost:5173

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat_app
JWT_SECRET=replace_me_with_a_long_random_string

# Email (optional; set all or none)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Chat App <redds4272@gmail.com>"

# Cloudinary media storage (recommended for production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Tokens
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60

# Scheduled messages processor (keep true on backend deploy)
RUN_SCHEDULED_MESSAGE_PROCESSOR=true
SCHEDULED_MESSAGE_POLL_MS=5000
SCHEDULED_MESSAGE_BATCH_SIZE=20
SCHEDULED_MESSAGE_ERROR_BACKOFF_MS=15000

# Google auth (optional)
GOOGLE_CLIENT_ID=

# Firebase Admin for mobile push notifications (set either the JSON or all split vars)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
